---
import Layout from '../layouts/Layout.astro';
const BASE = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Layout title="Learning Without Overwhelm">
    <div id="app-container" x-data="{ activeTab: 'overview' }">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>Command Center</h2>
            </div>
            <nav id="main-nav">
                <!-- We use HTMX to fetch the partials from Astro endpoints. 
                     Alpine.js handles the active class state. -->
                <button class="nav-btn" 
                    hx-get={BASE + "partials/overview"} 
                    hx-target="#content-area" 
                    :class="{'active': activeTab === 'overview'}" 
                    @click="activeTab = 'overview'">Overview</button>
                    
                <button class="nav-btn" 
                    hx-get={BASE + "partials/readings"} 
                    hx-target="#content-area" 
                    :class="{'active': activeTab === 'readings'}" 
                    @click="activeTab = 'readings'">Reading Library</button>
                    
                <button class="nav-btn" 
                    hx-get={BASE + "partials/weekly"} 
                    hx-target="#content-area" 
                    :class="{'active': activeTab === 'weekly'}" 
                    @click="activeTab = 'weekly'">Weekly Plan</button>
                    
                <button class="nav-btn" 
                    hx-get={BASE + "partials/prompts"} 
                    hx-target="#content-area" 
                    :class="{'active': activeTab === 'prompts'}" 
                    @click="activeTab = 'prompts'">Prompt Log</button>
                    
                <button class="nav-btn" 
                    hx-get={BASE + "partials/experiments"} 
                    hx-target="#content-area" 
                    :class="{'active': activeTab === 'experiments'}" 
                    @click="activeTab = 'experiments'">Experiment Log</button>
                    
                <button class="nav-btn" 
                    hx-get={BASE + "partials/links"} 
                    hx-target="#content-area" 
                    :class="{'active': activeTab === 'links'}" 
                    @click="activeTab = 'links'">Links</button>
                    
                <button class="nav-btn" 
                    hx-get={BASE + "partials/settings"} 
                    hx-target="#content-area" 
                    :class="{'active': activeTab === 'settings'}" 
                    @click="activeTab = 'settings'">Utilities</button>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            <header class="sticky-header" x-data="{
                readingsCount: 0,
                promptsCount: 0,
                experimentsCount: 0,
                updateStats() {
                    const r = JSON.parse(localStorage.getItem('lwo_dashboard_readings') || '[]');
                    const p = JSON.parse(localStorage.getItem('lwo_dashboard_prompts') || '[]');
                    const e = JSON.parse(localStorage.getItem('lwo_dashboard_experiments') || '[]');
                    this.readingsCount = r.length;
                    this.promptsCount = p.length;
                    this.experimentsCount = e.length;
                }
            }" x-init="updateStats(); window.addEventListener('storage', () => updateStats()); document.body.addEventListener('click', () => setTimeout(updateStats, 100))">
                <div class="header-titles">
                    <h1>Learning Without Overwhelm</h1>
                    <p class="tagline">Where learning feels manageable. Built with AHA Stack.</p>
                </div>
                <div class="header-stats">
                    <div class="stat"><span x-text="readingsCount"></span> Readings</div>
                    <div class="stat"><span x-text="promptsCount"></span> Prompts</div>
                    <div class="stat"><span x-text="experimentsCount"></span> Experiments</div>
                </div>
            </header>

            <!-- Sections Container -->
            <!-- We trigger a load right away to fetch the initial tab -->
            <div id="content-area" hx-get={BASE + "partials/overview"} hx-trigger="load">
                <div class="p-4">Loading application...</div>
            </div>
        </main>
    </div>
</Layout>
